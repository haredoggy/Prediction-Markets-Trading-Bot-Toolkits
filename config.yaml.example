# Polymarket Toolkits Configuration File
# Copy this file to config.yaml and fill in your sensitive values
# 
# NOTE: Only sensitive credentials are stored here. All other configuration
# is in config.json to allow easy version control without exposing secrets.

# ============================================================================
# Bot Configuration (Sensitive Credentials Only)
# ============================================================================
bot:
  # Your wallet's private key (64-character hex string, no 0x prefix)
  # KEEP THIS SECRET! Never share or commit to git!
  private_key: ""
  
  # Proxy wallet address (funder) for the account
  funder_address: "0x0000000000000000000000000000000000000000"
